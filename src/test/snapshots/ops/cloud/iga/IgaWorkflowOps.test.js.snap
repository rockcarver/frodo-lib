    "BasicApplicationGrant": {
      "draft": null,
      "published": {
        "_rev": 7,
        "childType": false,
        "description": "Basic request flow for granting a user an account in an application",
        "displayName": "Basic Application Grant",
        "id": "BasicApplicationGrant",
