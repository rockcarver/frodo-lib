        "staticNodes": {
          "endNode": {
            "connections": null,
            "id": "endNode",
            "x": 2822,
            "y": 352,
          },
          "startNode": {
            "connections": {
              "start": "scriptTask-4e9121fe850a",
            },
            "id": "startNode",
            "x": 70,
            "y": 140,
          },
          "uiConfig": {
            "approvalTask-74cf85c35437": {
              "actors": [
                {
                  "id": {
                    "isExpression": true,
                    "value": [
                      ""managed/user/" + requestIndex.applicationOwner[0].id",
                    ],
                  },
                  "type": "applicationOwner",
                },
              ],
