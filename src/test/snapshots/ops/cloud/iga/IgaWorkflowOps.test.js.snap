        id: "managed/user/" + requestIndex.applicationOwner[0].id,
        permissions: {
            approve: true,
            reject: true,
            reassign: true,
            modify: true,
            comment: true
        }
    }];
})()
**/
(
function(){
   return [];
}
)()",
