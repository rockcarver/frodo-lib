              },
            },
          },
        ],
      },
      "validation": {
        "source": "var validation = {"errors" : [], "comments" : []};if(object.requester.id.startsWith("managed/user/")){var userId = object.requester.id.split('/');try{var user = openidm.action("iga/governance/user", 'GET', {}, {"endUserId": userId[2], "scopePermission": "createUser", "_queryFilter": "id+eq+'" + userId[2] + "'"});if(user.result.length === 0){validation.errors.push("User does not have permission to create users.");}}catch(e){validation.errors.push("User does not have permission to create users." + e)}}if(systemSettings.settings.requireRequestJustification === true && (request.common.justification == undefined || request.common.justification.trim() == "")){validation.errors.push("Justification is required");}validation;",
      },
      "workflow": {
        "id": "CreateUser",
        "type": "bpmn",
      },
    },
