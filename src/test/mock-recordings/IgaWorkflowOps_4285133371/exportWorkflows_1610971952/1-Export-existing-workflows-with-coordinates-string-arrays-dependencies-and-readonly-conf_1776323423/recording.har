Internal\":true}}},\"properties\":{\"justification\":{\"type\":\"text\"},\"externalRequestId\":{\"type\":\"text\"},\"requestIdPrefix\":{\"type\":\"text\"},\"isDraft\":{\"type\":\"boolean\"},\"priority\":{\"type\":\"text\"},\"expiryDate\":{\"type\":\"text\"},\"context\":{\"type\":\"object\"},\"workflowId\":{\"type\":\"text\"},\"startDate\":{\"type\":\"text\"},\"endDate\":{\"type\":\"text\"},\"blob\":{\"type\":\"object\"}}}],\"entitlement\":[{\"_meta\":{\"type\":\"system\",\"display\":\"Entitlement Creation\",\"properties\":{\"applicationId\":{\"isRequired\":true,\"isInternal\":true,\"isMultiValue\":false,\"lookup\":{\"path\":\"/iga/index/catalog\",\"query\":\"application/id/keyword eq \\\"${applicationId}\\\" and item/type/keyword eq \\\"accountGrant\\\"\"},\"display\":{\"name\":\"Application\",\"isVisible\":true,\"order\":1,\"description\":\"The application that the entitlement belongs to\"}},\"objectType\":{\"isRequired\":true,\"isInternal\":true,\"isMultiValue\":false,\"display\":{\"name\":\"Object Type\",\"isVisible\":true,\"description\":\"Object type of the entitlement in the external system (e.g. __GROUP__)\"}},\"object\":{\"isRequired\":false,\"isInternal\":true,\"display\":{\"name\":\"Entitlement Contents\",\"isVisible\":true,\"description\":\"The contents of the entitlement object (technical data)\"}},\"glossary\":{\"isRequired\":false,\"isInternal\":true,\"display\":{\"name\":\"Glossary\",\"isVisible\":true,\"description\":\"The contents of the entitlement's glossary (business data)\"}}}},\"properties\":{\"applicationId\":{\"type\":\"text\"},\"objectType\":{\"type\":\"text\"},\"object\":{\"type\":\"object\"},\"glossary\":{\"type\":\"object\"}}}]},\"workflow\":{\"id\":\"CreateEntitlement\",\"type\":\"bpmn\"},\"validation\":{\"source\":\"var validation = {\\\"errors\\\" : [], \\\"comments\\\" : []};if(object.requester.id.startsWith(\\\"managed/user/\\\")){var userId = object.requester.id.split('/');try{var application = openidm.action(\\\"iga/governance/appl