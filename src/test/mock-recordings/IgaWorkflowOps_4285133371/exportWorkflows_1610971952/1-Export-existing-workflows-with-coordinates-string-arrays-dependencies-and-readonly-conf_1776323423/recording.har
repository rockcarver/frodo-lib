            "text": "{\"name\":\"pgh-generate-rap\",\"type\":\"request\",\"description\":\"Form for generating an RAP code for a user\",\"categories\":{\"applicationType\":null,\"objectType\":null,\"operation\":\"create\"},\"form\":{\"fields\":[{\"id\":\"e530afc3-db58-460d-b5d9-687b54a0c381\",\"fields\":[{\"id\":\"be5596da-1cda-4576-b126-ca4e74eebce4\",\"model\":\"custom.idPath\",\"type\":\"select\",\"label\":\"Select a User\",\"description\":\"\",\"validation\":{\"required\":true},\"layout\":{\"columns\":4,\"offset\":4},\"options\":{\"object\":\"user\",\"queryFilter\":\"true\"},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}]},{\"id\":\"f31def11-67b0-4f20-855c-d0230901703e\",\"fields\":[{\"id\":\"d460e467-933f-42e6-93ef-d61e43dbb6f1\",\"model\":\"custom.rap\",\"type\":\"string\",\"label\":\"RAP\",\"description\":\"\",\"validation\":{\"required\":true,\"regex\":{}},\"layout\":{\"columns\":4,\"offset\":4},\"defaultValue\":\"\",\"readOnly\":true,\"customSlot\":false,\"onChangeEvent\":{}}]}],\"events\":{\"onLoad\":{\"type\":\"script\",\"script\":\"const USER_FIELD = 'custom.idPath';\\nconst RAP_FIELD = 'custom.rap';\\n\\nfunction main() {\\n    if (form.getValue(RAP_FIELD)) {\\n        form.hideField(USER_FIELD);\\n    } else {\\n        form.hideField(RAP_FIELD);\\n    }\\n}\\n\\nmain();\"}}},\"id\":\"69c4d900-ff3c-400f-8d18-037693ade1fc\",\"_rev\":37,\"metadata\":{\"modifiedDate\":\"2026-03-31T15:46:57.582Z\",\"createdDate\":\"2026-03-23T15:49:19.122652941Z\"}}"
