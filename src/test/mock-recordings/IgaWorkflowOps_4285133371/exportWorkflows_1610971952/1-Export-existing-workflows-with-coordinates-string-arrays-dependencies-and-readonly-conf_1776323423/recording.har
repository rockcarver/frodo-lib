d/user/\\\" + ((requestIndex.entitlementOwner && requestIndex.entitlementOwner.length > 0) ? requestIndex.entitlementOwner[0].id : requestIndex.applicationOwner[0].id)\",\"isExpression\":true}}],\"events\":{\"reminderDate\":3,\"reminderTimeSpan\":\"day(s)\",\"expirationDate\":7,\"expirationDateType\":\"duration\",\"expirationTimeSpan\":\"day(s)\",\"expirationDateVariable\":\"\"},\"x\":722,\"y\":156},\"scriptTask-3eab1948f1ec\":{\"x\":1434,\"y\":95.015625},\"exclusiveGateway-48e748c42994\":{\"x\":1731,\"y\":88.015625},\"scriptTask-0b56191887de\":{\"x\":1979,\"y\":212.015625},\"scriptTask-0359a9d77ee2\":{\"x\":1972,\"y\":119.015625},\"scriptTask-aec6c36b3a45\":{\"x\":1441,\"y\":268.015625},\"scriptTask-e04f42607ba5\":{\"x\":186,\"y\":143.015625},\"scriptTask-e21178ab80f7\":{\"x\":716,\"y\":74.015625},\"exclusiveGateway-67a954f33919\":{\"x\":467,\"y\":121.015625},\"inclusiveGateway-3f85f36eeeef\":{\"x\":948,\"y\":57.015625},\"waitTask-0d53639996da\":{\"x\":1208,\"y\":30.015625,\"events\":{\"resumeDateType\":\"requestProp\",\"resumeDateNumber\":1,\"resumeDateTimeSpan\":\"day(s)\",\"resumeDateRequestProperty\":\"request.common.startDate\"}},\"inclusiveGateway-f105ed2b352d\":{\"x\":2255,\"y\":48.015625},\"scriptTask-91769554db51\":{\"x\":2561,\"y\":74.015625}}},\"status\":\"published\",\"mutable\":true}"
