            "mimeType": "application/json; charset=utf-8",
            "size": 4022,
            "text": "{\"name\":\"phh-new-user\",\"type\":\"request\",\"description\":\"Request new user\",\"categories\":{\"applicationType\":null,\"objectType\":null,\"operation\":\"create\"},\"form\":{\"fields\":[{\"fields\":[{\"id\":\"a221cdbe-3e28-4d98-91b5-4f99bca8ccf6\",\"model\":\"custom.givenName\",\"type\":\"string\",\"label\":\"Given Name\",\"description\":\"First Name\",\"validation\":{\"required\":true},\"layout\":{\"columns\":12,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}],\"id\":\"d3488e29-dde5-4406-873f-3e99ee818508\"},{\"fields\":[{\"id\":\"8e398b29-4229-4fec-a37c-d95a91928864\",\"model\":\"custom.sn\",\"type\":\"string\",\"label\":\"Surname\",\"description\":\"Last Name\",\"validation\":{\"required\":true,\"regex\":{}},\"layout\":{\"columns\":12,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}],\"id\":\"312caf93-1aa9-4659-b076-cef7a6fc9f39\"},{\"fields\":[{\"id\":\"02cf58e1-d05b-4b24-84e2-073b56fe033f\",\"model\":\"custom.mail\",\"type\":\"string\",\"label\":\"Personal eMail\",\"description\":\"Email address\",\"validation\":{\"required\":true},\"layout\":{\"columns\":6,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}},{\"id\":\"3bb65f28-6f65-45aa-b2c6-4a6d1d90ce73\",\"type\":\"string\",\"label\":\"Cell number\",\"description\":\"Individual cell phone number. (Needed for Duo server access)\",\"validation\":{\"required\":true,\"regex\":{\"message\":\"Please correct your phone number.\",\"pattern\":\"^(\\\\+0?1\\\\s)?\\\\(?\\\\d{3}\\\\)?[\\\\s.-]?\\\\d{3}[\\\\s.-]?\\\\d{4}$\"}},\"layout\":{\"columns\":6,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}],\"id\":\"6fd16bae-ea14-43db-ac27-b0dfad060b46\"},{\"fields\":[{\"id\":\"dfeba91e-5141-4da6-97f3-4ad520e64334\",\"model\":\"custom.positionSelect\",\"type\":\"select\",\"label\":\"Position\",\"description\":\"Position\",\"validation\":{\"required\":true},\"layout\":{\"columns\":6,\"offset\":0},\"options\":[{\"label\":\"One\",\"selectedByDefault\":true,\"value\":\"positionOne\"},{\"label\":\"Two\",\"value\":\"positionTwo\"},{\"label\":\"Other\",\"value\":\"positionOther\"}],\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{\"script\":\"// Get the newly selected value\\nvar selectedPosition = form.currentFieldValue;\\n\\n//console.log('Position changed to:', selectedPosition);\\n\\nif (selectedPosition === 'positionOther') {\\n    // Show the text field and enable it\\n    form.showField('custom.positionOther');\\n    form.enableField('custom.positionOther');\\n} else {\\n    // Hide the text field and clear any value\\n    form.hideField('custom.positionOther');\\n    form.setValue('custom.positionOther', '');\\n    \\n    // Optionally disable it as well (though hidden fields are already non-interactive)\\n    form.disableField('custom.positionOther');\\n}\",\"type\":\"script\"}},{\"id\":\"5081c59a-016c-4ac3-a518-45123a34cd22\",\"model\":\"custom.positionOther\",\"type\":\"string\",\"label\":\"\",\"description\":\"Please provide a position\",\"validation\":{\"required\":true},\"layout\":{\"columns\":6,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}],\"id\":\"4d5bbe99-4c48-48f2-9c02-16c194c95a8e\"},{\"fields\":[{\"id\":\"855991a5-6ac8-4bc0-91a6-c1b156e9832c\",\"model\":\"custom.startDate\",\"type\":\"date\",\"label\":\"Start Date\",\"description\":\"Start Date\",\"validation\":{\"required\":true},\"layout\":{\"columns\":6,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}},{\"id\":\"e1687d03-9db3-4f3b-8939-5bb42893a165\",\"model\":\"custom.endDate\",\"type\":\"date\",\"label\":\"End Date\",\"description\":\"End Date\",\"validation\":{\"required\":true},\"layout\":{\"columns\":6,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}],\"id\":\"d36ce194-5b64-452a-bb10-b99a30ce8038\"}],\"events\":{\"onLoad\":{\"type\":\"script\",\"script\":\"form.hideField('custom.positionOther');\\nform.setValue('custom.positionOther', '');\\n\\n\\n// Pre-populate a read-only field with data from the request\\nvar requestedMail = form.urlParams['custom.mail'];\\nif (requestedMail) {\\n  form.setValue('custom.mail', requestedMail);\\n      form.disableField('custom.mail'); // Make it read-only for the approver\\n}\"}}},\"id\":\"c385b530-b912-4dcd-98c8-931673add9b7\",\"_rev\":36,\"metadata\":{\"modifiedDate\":\"2026-03-25T22:45:43.139Z\",\"createdDate\":\"2025-12-15T16:46:29.581505111Z\"}}"
